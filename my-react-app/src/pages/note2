const normalizeText = (value = "") =>
  String(value)
    .toLowerCase()
    .replace(/[\s_\-./()]+/g, "")
    .trim();

const toNumber = (value) => {
  if (value === null || value === undefined || value === "") return 0;
  const cleaned = String(value).replace(/,/g, "").trim();
  const num = Number(cleaned);
  return Number.isFinite(num) ? num : 0;
};

const getHeaderRowIndex = (sheetData) => {
  for (let i = 0; i < Math.min(sheetData.length, 12); i++) {
    const row = (sheetData[i] || []).map(cell => normalizeText(cell));
    const rowText = row.join("|");
    if (
      rowText.includes("taxablevalue") ||
      rowText.includes("integratedtaxamount") ||
      rowText.includes("integratedtax") ||
      rowText.includes("centraltaxamount") ||
      rowText.includes("stateuttaxamount") ||
      rowText.includes("invoicevalue")
    ) {
      return i;
    }
  }
  return 3;
};

const sheetToObjects = (worksheet) => {
  const raw = XLSX.utils.sheet_to_json(worksheet, { header: 1, defval: "" });
  if (!raw || raw.length === 0) return [];

  const headerRowIndex = getHeaderRowIndex(raw);
  const headers = (raw[headerRowIndex] || []).map(h => String(h || "").trim());

  return raw.slice(headerRowIndex + 1).map((row) => {
    const obj = {};
    headers.forEach((header, index) => {
      obj[header] = row[index];
    });
    return obj;
  });
};

const getValueByPossibleHeaders = (row, possibleHeaders) => {
  const entries = Object.entries(row || {});
  for (const [key, value] of entries) {
    const normalizedKey = normalizeText(key);
    if (possibleHeaders.some(h => normalizedKey === normalizeText(h))) {
      return value;
    }
  }
  return "";
};

const getImportSummaryKey = (option) => {
  const v = normalizeText(option);

  if (v.includes("b2b")) return "b2b";
  if (v.includes("b2cl")) return "b2cLarge";
  if (v === "b2c" || v.includes("b2cothers")) return "b2cOthers";
  if (v.includes("14a")) return "eco";
  if (v.includes("hsn")) return "hsn";

  return null;
};

const getPossibleSheetNames = (option) => {
  const v = normalizeText(option);

  if (v.includes("b2b")) return ["b2b,sez,de", "b2b", "sez", "de"];
  if (v.includes("b2cl")) return ["b2cl"];
  if (v === "b2c" || v.includes("b2cothers")) return ["b2cs", "b2c"];
  if (v.includes("14a")) return ["ecoa", "14a", "ecoa14a"];
  if (v.includes("hsn")) return ["hsn(b2b)", "hsn(b2c)", "hsn"];

  return [];
};

const pickMatchingSheet = (workbook, option) => {
  const wanted = getPossibleSheetNames(option).map(normalizeText);
  if (!wanted.length) return null;

  for (const sheetName of workbook.SheetNames) {
    const normalizedSheet = normalizeText(sheetName);
    if (wanted.some(name => normalizedSheet.includes(name) || name.includes(normalizedSheet))) {
      return workbook.Sheets[sheetName];
    }
  }
  return null;
};

const calculateSummaryFromRows = (rows) => {
  let taxable = 0;
  let igst = 0;
  let cgst = 0;
  let sgst = 0;
  let cess = 0;

  rows.forEach((row) => {
    taxable += toNumber(
      getValueByPossibleHeaders(row, [
        "Taxable Value",
        "Total Taxable Value",
        "Revised Taxable Value",
        "Net value of supplies",
        "Taxable value"
      ])
    );

    igst += toNumber(
      getValueByPossibleHeaders(row, [
        "Integrated Tax Amount",
        "Integrated tax",
        "IGST",
        "Total Integrated Tax"
      ])
    );

    cgst += toNumber(
      getValueByPossibleHeaders(row, [
        "Central Tax Amount",
        "Central tax",
        "CGST",
        "Total Central Tax"
      ])
    );

    sgst += toNumber(
      getValueByPossibleHeaders(row, [
        "State/UT Tax Amount",
        "State/UT tax",
        "SGST",
        "UTGST",
        "Total State/UT Tax"
      ])
    );

    cess += toNumber(
      getValueByPossibleHeaders(row, [
        "Cess Amount",
        "Cess",
        "Total Cess"
      ])
    );
  });

  return {
    taxable,
    igst,
    cgst,
    sgst,
    cess,
    total: taxable + igst + cgst + sgst + cess
  };
};

const applyImportedSummary = (option, totals) => {
  const key = getImportSummaryKey(option);
  if (!key) return;

  setSummaryTotals(prev => ({
    ...prev,
    [key]: {
      taxable: totals.taxable || 0,
      igst: totals.igst || 0,
      cgst: totals.cgst || 0,
      sgst: totals.sgst || 0,
      cess: totals.cess || 0,
      total: totals.total || 0
    }
  }));
};

const handleImportFile = async () => {
  if (!uploadedFile) {
    alert("Please select a file first.");
    return;
  }

  if (!selectedOptions.length) {
    alert("Please select at least one import section.");
    return;
  }

  try {
    setIsUploading(true);

    const buffer = await uploadedFile.arrayBuffer();
    const workbook = XLSX.read(buffer, { type: "array" });

    selectedOptions.forEach((option) => {
      const sheet = pickMatchingSheet(workbook, option);

      if (!sheet) {
        applyImportedSummary(option, {
          taxable: 0,
          igst: 0,
          cgst: 0,
          sgst: 0,
          cess: 0,
          total: 0
        });
        return;
      }

      const rows = sheetToObjects(sheet);

      const filteredRows = rows.filter((row) =>
        Object.values(row || {}).some(value => String(value || "").trim() !== "")
      );

      if (!filteredRows.length) {
        applyImportedSummary(option, {
          taxable: 0,
          igst: 0,
          cgst: 0,
          sgst: 0,
          cess: 0,
          total: 0
        });
        return;
      }

      const totals = calculateSummaryFromRows(filteredRows);
      applyImportedSummary(option, totals);
    });

    setActiveSubTab("Summary");
    setImportStep("sources");
    setUploadedFile(null);
    alert("Excel imported successfully.");
  } catch (error) {
    console.error("Import failed:", error);
    alert("File read failed. Summary set to zero for invalid sections.");
  } finally {
    setIsUploading(false);
  }
};

